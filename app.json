{
  "expo": {
    "owner": "david_salib",
    "name": "Coptic Lent",
    "slug": "TheCopticLentApp",
    "version": "1.0.3",
    "orientation": "portrait",
    "install": {
      "exclude": [
        "react-native@~0.76.6",
        "react-native-reanimated@~3.16.1",
        "react-native-screens@~4.4.0",
        "react-native-safe-area-context@~4.12.0"
      ]
    },
    "icon": "./assets/images/lent-app-icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/lent-app-splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7D000C",
      "width": 300
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.davidsalib.LentApp",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/lent-app-icon.png",
        "backgroundColor": "#6D000B"
      },
      "package": "com.davidsalib.LentApp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "df5b2253-4279-4715-9928-667853b9e6d9"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/df5b2253-4279-4715-9928-667853b9e6d9"
    }
  }
}
